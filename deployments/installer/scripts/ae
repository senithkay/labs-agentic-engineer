#!/usr/bin/env bash
set -euo pipefail

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Output helpers ────────────────────────────────────────────────────────────
info()    { printf "${GREEN}  ✓${RESET}  %s\n" "$*"; }
warn()    { printf "${YELLOW}  !${RESET}  %s\n" "$*"; }
error()   { printf "${RED}  ✗${RESET}  %s\n" "$*" >&2; }
banner()  { printf "\n${BOLD}%s${RESET}\n" "$*"; }
divider() { printf '%s\n' "  ────────────────────────────────────────────────"; }

# ── Input helpers ─────────────────────────────────────────────────────────────
# prompt_default VAR "Prompt text" "default value"
# Prints:  ▶  Prompt text [default value]:
# Stores the user input (or default if blank) in VAR.
prompt_default() {
  local _var="$1" _text="$2" _default="$3"
  printf "${CYAN}  ▶${RESET}  %s [%s]: " "$_text" "$_default"
  local _val
  IFS= read -r _val
  printf -v "$_var" '%s' "${_val:-${_default}}"
}

# prompt_secret VAR "Prompt text" "default value"
# Like prompt_default but input is masked. Shows first4**** or "auto-generate" as hint.
prompt_secret() {
  local _var="$1" _text="$2" _default="$3"
  local _hint
  if [ -n "$_default" ]; then
    _hint="${_default:0:4}****"
  else
    _hint="auto-generate"
  fi
  printf "${CYAN}  ▶${RESET}  %s [%s]: " "$_text" "$_hint"
  local _val
  IFS= read -rs _val
  echo
  printf -v "$_var" '%s' "${_val:-${_default}}"
}

# mask VALUE — prints first 4 chars + **** (or "(empty)")
mask() {
  local s="$1"
  if [ -z "$s" ]; then printf '(empty)'; return; fi
  if [ "${#s}" -le 4 ]; then printf '****'; return; fi
  printf '%s****' "${s:0:4}"
}

# ── OpenBao helpers ───────────────────────────────────────────────────────────
OPENBAO_ADDR="http://openbao.openbao.svc.cluster.local:8200"
OPENBAO_TOKEN="root"

# seed_openbao PATH VALUE — always writes (KV v2 POST)
seed_openbao() {
  local path="$1" value="$2"
  local encoded_value json
  encoded_value=$(printf '%s' "$value" | jq -Rs .)
  json="{\"data\":{\"value\":${encoded_value}}}"
  curl -sf \
    -H "X-Vault-Token: ${OPENBAO_TOKEN}" \
    -H "Content-Type: application/json" \
    -X POST -d "$json" \
    "${OPENBAO_ADDR}/v1/secret/data/${path}" > /dev/null
}

# seed_if_not_exists PATH VALUE — only writes if path has no existing value
seed_if_not_exists() {
  local path="$1" value="$2"
  local status
  status=$(curl -s -o /dev/null -w "%{http_code}" \
    -H "X-Vault-Token: ${OPENBAO_TOKEN}" \
    "${OPENBAO_ADDR}/v1/secret/data/${path}" 2>/dev/null || printf '000')
  if [ "$status" = "404" ] || [ "$status" = "000" ]; then
    seed_openbao "$path" "$value"
    info "seeded  $path"
  else
    info "skipped $path (already exists)"
  fi
}

# ── Banner ────────────────────────────────────────────────────────────────────
print_banner() {
  printf "${BOLD}${CYAN}"
  cat <<'BANNER'

    ___   ___   ___  _____  _     ___
   / _ \ / __| |   \|_   _|| |   / __|
  | (_) | (__  | |) | | |  | |__ \__ \
   \__\_\\___| |___/  |_|  |____||___/

BANNER
  printf "${RESET}"
  printf "  ${BOLD}WSO2 Agentic Engineer Platform Installer${RESET}\n"
  printf "  Version: 0.0.0-dev\n\n"
}

# ── Help ──────────────────────────────────────────────────────────────────────
cmd_help() {
  printf "Usage: ae <command>\n\n"
  printf "Commands:\n"
  printf "  install    Install AE platform on this OC cluster\n"
  printf "  help       Show this help\n\n"
  printf "Example:\n"
  printf "  kubectl exec -it -n ae-system pod/ae-installer -- /scripts/ae install\n\n"
}

# ── Install ───────────────────────────────────────────────────────────────────
cmd_install() {
  print_banner

  # ── Step 2: IDP selection ──────────────────────────────────────────────────
  banner "Identity Provider"
  while true; do
    printf "  [1] Thunder (WSO2)\n"
    printf "  [2] Other  (coming soon)\n"
    printf "${CYAN}  ▶${RESET}  Select IDP [1]: "
    local idp_choice
    IFS= read -r idp_choice
    idp_choice="${idp_choice:-1}"
    case "$idp_choice" in
      1) info "Thunder selected"; break ;;
      2) warn "Other IDPs are coming soon. Currently only Thunder is supported."; echo ;;
      *) warn "Invalid choice. Enter 1 or 2." ;;
    esac
  done

  # ── Step 3: Secret backend selection ──────────────────────────────────────
  banner "Secret Backend"
  while true; do
    printf "  [1] OpenBao\n"
    printf "  [2] Other  (coming soon)\n"
    printf "${CYAN}  ▶${RESET}  Select secret backend [1]: "
    local sb_choice
    IFS= read -r sb_choice
    sb_choice="${sb_choice:-1}"
    case "$sb_choice" in
      1) info "OpenBao selected"; break ;;
      2) warn "Other secret backends are coming soon. Currently only OpenBao is supported."; echo ;;
      *) warn "Invalid choice. Enter 1 or 2." ;;
    esac
  done

  # ── Step 4: Detect Thunder ────────────────────────────────────────────────
  local THUNDER_ADMIN_URL="http://thunder-service.thunder.svc.cluster.local:8090"
  local THUNDER_PUBLIC_URL="http://thunder.openchoreo.localhost:8080"

  banner "Detecting Thunder"
  if helm list -n thunder -q 2>/dev/null | grep -q "^thunder$"; then
    info "Thunder detected (Helm release 'thunder' in namespace 'thunder')"
  else
    warn "Thunder Helm release not found in namespace 'thunder'"
    while true; do
      printf "  [1] Provide Thunder URLs manually\n"
      printf "  [2] Install new Thunder instance (coming soon)\n"
      printf "${CYAN}  ▶${RESET}  Select [1]: "
      local t_choice
      IFS= read -r t_choice
      t_choice="${t_choice:-1}"
      case "$t_choice" in
        1)
          prompt_default THUNDER_ADMIN_URL  "Thunder admin URL"  "$THUNDER_ADMIN_URL"
          prompt_default THUNDER_PUBLIC_URL "Thunder public URL" "$THUNDER_PUBLIC_URL"
          break
          ;;
        2) warn "Installing new Thunder is coming soon."; echo ;;
        *) warn "Invalid choice. Enter 1 or 2." ;;
      esac
    done
  fi

  # ── Step 5: Detect OpenBao ────────────────────────────────────────────────
  banner "Detecting OpenBao"
  if helm list -n openbao -q 2>/dev/null | grep -q "^openbao$"; then
    info "OpenBao detected (Helm release 'openbao' in namespace 'openbao')"
  else
    warn "OpenBao Helm release not found in namespace 'openbao'"
    while true; do
      printf "  [1] Provide OpenBao address manually\n"
      printf "  [2] Install new OpenBao instance (coming soon)\n"
      printf "${CYAN}  ▶${RESET}  Select [1]: "
      local ob_choice
      IFS= read -r ob_choice
      ob_choice="${ob_choice:-1}"
      case "$ob_choice" in
        1)
          prompt_default OPENBAO_ADDR "OpenBao address" "$OPENBAO_ADDR"
          break
          ;;
        2) warn "Installing new OpenBao is coming soon."; echo ;;
        *) warn "Invalid choice. Enter 1 or 2." ;;
      esac
    done
  fi

  # ── Step 6: OpenBao token ─────────────────────────────────────────────────
  banner "OpenBao Access"
  prompt_secret OPENBAO_TOKEN "OpenBao root token" "$OPENBAO_TOKEN"

  # ── Step 7: Platform URLs and service secrets ─────────────────────────────
  local BFF_PUBLIC_URL="http://asdlc-api.openchoreo.localhost:8080"
  local CONSOLE_PUBLIC_URL="http://asdlc.openchoreo.localhost:8080"
  local SMEE_URL=""
  local THUNDER_SYSTEM_CLIENT_SECRET="asdlc-system-client-secret"
  local SERVICE_AUTH_CLIENT_SECRET="asdlc-api-client-secret"
  local SERVICE_AUTH_GIT_SECRET="asdlc-bff-to-git-service-secret"
  local SERVICE_AUTH_AGENTS_SECRET="asdlc-bff-to-agents-service-secret"
  local OBSERVER_CLIENT_SECRET="openchoreo-observer-resource-reader-client-secret"
  local WEBHOOK_SECRET=""
  local OAUTH_STATE_KEY=""

  banner "Platform URLs"
  prompt_default BFF_PUBLIC_URL     "Public BFF URL"                              "$BFF_PUBLIC_URL"
  prompt_default CONSOLE_PUBLIC_URL "Public console URL"                          "$CONSOLE_PUBLIC_URL"
  prompt_default SMEE_URL           "GitHub webhook proxy URL (smee.io, optional)" "$SMEE_URL"

  banner "Service Secrets"
  printf "  Internal service-to-service client secrets.\n"
  printf "  Press Enter to accept the defaults (correct for standard OC dev installs).\n\n"
  prompt_secret THUNDER_SYSTEM_CLIENT_SECRET "Thunder system client secret"  "$THUNDER_SYSTEM_CLIENT_SECRET"
  prompt_secret SERVICE_AUTH_CLIENT_SECRET   "Service auth client secret"    "$SERVICE_AUTH_CLIENT_SECRET"
  prompt_secret SERVICE_AUTH_GIT_SECRET      "BFF → git-service secret"      "$SERVICE_AUTH_GIT_SECRET"
  prompt_secret SERVICE_AUTH_AGENTS_SECRET   "BFF → agents-service secret"   "$SERVICE_AUTH_AGENTS_SECRET"
  prompt_secret OBSERVER_CLIENT_SECRET       "Observer OAuth client secret"  "$OBSERVER_CLIENT_SECRET"

  banner "Generated Secrets"
  printf "  Press Enter to auto-generate, or paste your own value.\n\n"
  prompt_secret WEBHOOK_SECRET  "GitHub webhook secret"  ""
  prompt_secret OAUTH_STATE_KEY "GitHub OAuth state key" ""

  # ── Step 8: Resolve auto-generated secrets ────────────────────────────────
  [ -z "$WEBHOOK_SECRET" ]  && WEBHOOK_SECRET=$(openssl rand -hex 32)
  [ -z "$OAUTH_STATE_KEY" ] && OAUTH_STATE_KEY=$(openssl rand -hex 32)

  # ── Step 9: Confirmation summary ──────────────────────────────────────────
  echo
  banner "Installation Summary"
  divider
  printf "  %-44s %s\n" "Thunder admin URL:"             "$THUNDER_ADMIN_URL"
  printf "  %-44s %s\n" "Thunder public URL:"            "$THUNDER_PUBLIC_URL"
  printf "  %-44s %s\n" "OpenBao address:"               "$OPENBAO_ADDR"
  printf "  %-44s %s\n" "BFF public URL:"                "$BFF_PUBLIC_URL"
  printf "  %-44s %s\n" "Console public URL:"            "$CONSOLE_PUBLIC_URL"
  [ -n "$SMEE_URL" ] && printf "  %-44s %s\n" "Webhook proxy URL:" "$SMEE_URL"
  printf "  %-44s %s\n" "Thunder system client secret:"  "$(mask "$THUNDER_SYSTEM_CLIENT_SECRET")"
  printf "  %-44s %s\n" "Service auth client secret:"    "$(mask "$SERVICE_AUTH_CLIENT_SECRET")"
  printf "  %-44s %s\n" "BFF→git-service secret:"        "$(mask "$SERVICE_AUTH_GIT_SECRET")"
  printf "  %-44s %s\n" "BFF→agents-service secret:"     "$(mask "$SERVICE_AUTH_AGENTS_SECRET")"
  printf "  %-44s %s\n" "Observer client secret:"        "$(mask "$OBSERVER_CLIENT_SECRET")"
  printf "  %-44s %s\n" "GitHub webhook secret:"         "$(mask "$WEBHOOK_SECRET")"
  printf "  %-44s %s\n" "GitHub OAuth state key:"        "$(mask "$OAUTH_STATE_KEY")"
  divider

  printf "\n${CYAN}  ▶${RESET}  Proceed with installation? [Y/n]: "
  local confirm
  IFS= read -r confirm
  confirm="${confirm:-Y}"
  case "$confirm" in
    [Yy]*) ;;
    *) warn "Installation cancelled."; exit 0 ;;
  esac

  # ── Step 10: Seed secrets into OpenBao ────────────────────────────────────
  echo
  banner "Seeding secrets into OpenBao"

  local DB_URL="postgres://asdlc:asdlc-dev-password@asdlc-db:5432/asdlc?sslmode=disable"
  seed_if_not_exists "asdlc/platform/db/url"                        "$DB_URL"
  seed_if_not_exists "asdlc/platform/thunder/system-client-secret"  "$THUNDER_SYSTEM_CLIENT_SECRET"
  seed_if_not_exists "asdlc/platform/service-auth/client-secret"    "$SERVICE_AUTH_CLIENT_SECRET"
  seed_if_not_exists "asdlc/platform/service-auth/git-secret"       "$SERVICE_AUTH_GIT_SECRET"
  seed_if_not_exists "asdlc/platform/service-auth/agents-secret"    "$SERVICE_AUTH_AGENTS_SECRET"
  seed_if_not_exists "asdlc/platform/observer/client-secret"        "$OBSERVER_CLIENT_SECRET"
  seed_if_not_exists "asdlc/platform/github/client-secret"          ""
  seed_openbao       "asdlc/platform/github/webhook-secret"         "$WEBHOOK_SECRET"
  info "seeded  asdlc/platform/github/webhook-secret"
  seed_openbao       "asdlc/platform/github/oauth-state-key"        "$OAUTH_STATE_KEY"
  info "seeded  asdlc/platform/github/oauth-state-key"

  # ── Step 11: Helm install ─────────────────────────────────────────────────
  echo
  banner "Installing AE platform"

  # Detect k3d cluster by checking if the first node name starts with "k3d-".
  # kubectl config current-context is not available inside a pod (in-cluster auth),
  # so we query the API directly instead.
  local pull_policy_flags=""
  local first_node
  first_node=$(kubectl get nodes -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || echo "")
  if printf '%s' "$first_node" | grep -q "^k3d-"; then
    warn "k3d cluster detected — setting imagePullPolicy: IfNotPresent for service images"
    pull_policy_flags="--set wso2-ae-platform.asdlcApi.image.pullPolicy=IfNotPresent \
      --set wso2-ae-platform.agentsService.image.pullPolicy=IfNotPresent \
      --set wso2-ae-platform.console.image.pullPolicy=IfNotPresent"
  fi

  helm upgrade --install wso2-ae-bundle /charts/wso2-agentic-engineer-bundle \
    --namespace wso2-ae --create-namespace \
    --set "wso2-ae-platform.openbao.addr=${OPENBAO_ADDR}" \
    --set "wso2-ae-platform.bff.publicURL=${BFF_PUBLIC_URL}" \
    --set "wso2-ae-platform.console.publicURL=${CONSOLE_PUBLIC_URL}" \
    --set "wso2-ae-platform.console.thunderPublicURL=${THUNDER_PUBLIC_URL}" \
    --set "wso2-ae-platform.idp.issuer=${THUNDER_PUBLIC_URL}" \
    --set "wso2-ae-platform.idp.jwksURL=${THUNDER_PUBLIC_URL}/oauth2/jwks" \
    --set "thunder.adminURL=${THUNDER_ADMIN_URL}" \
    --set "thunder.publicURL=${THUNDER_PUBLIC_URL}" \
    --set "bff.publicURL=${BFF_PUBLIC_URL}" \
    --set "console.publicURL=${CONSOLE_PUBLIC_URL}" \
    ${SMEE_URL:+--set "smee.url=${SMEE_URL}"} \
    ${pull_policy_flags}

  # ── Step 12: Health check ─────────────────────────────────────────────────
  echo
  banner "Verifying deployment"
  info "Waiting for asdlc-api..."
  kubectl rollout status deployment/asdlc-api      -n wso2-ae --timeout=120s
  info "Waiting for agents-service..."
  kubectl rollout status deployment/agents-service  -n wso2-ae --timeout=120s
  info "Waiting for asdlc-console..."
  kubectl rollout status deployment/asdlc-console   -n wso2-ae --timeout=120s

  echo
  divider
  printf "${GREEN}${BOLD}  AE Platform installed successfully!${RESET}\n\n"
  printf "  Console:     ${CYAN}%s${RESET}\n" "$CONSOLE_PUBLIC_URL"
  printf "  Credentials: admin / admin\n"
  printf "  Next step:   Configure GitHub integration via Settings\n"
  divider
  echo
}

# ── Entrypoint ────────────────────────────────────────────────────────────────
case "${1:-help}" in
  install) cmd_install ;;
  help|--help|-h) cmd_help ;;
  *) error "Unknown command: $1"; echo; cmd_help; exit 1 ;;
esac
